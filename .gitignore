# ============================================================
# .gitignore for Symbi.ai
# RULE: If it contains secrets, credentials, or locally
# generated files — it does NOT go on GitHub.
# ============================================================

# --- SECRETS (most critical) ---
# Your API keys and JWT secret live here.
# If this file reaches GitHub, anyone can steal your Groq credits.
.env

# --- DATABASE (contains real user data) ---
# symbi.db has usernames, hashed passwords, and hint history.
# Never commit user data to a public repo.
*.db
*.sqlite
*.sqlite3

# --- PYTHON ---
# __pycache__ is Python's compiled bytecode cache. Auto-generated, not source code.
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Python virtual environments — huge folders with installed packages.
# Teammates install their own via: pip install -r requirements.txt
venv/
env/
.venv/
.env/

# Python build artifacts
*.egg-info/
dist/
build/
.eggs/

# --- NODE / REACT ---
# node_modules is the largest folder in the universe.
# It gets re-downloaded via: npm install
# Never ever commit this. It can be 200MB+ with 50,000+ files.
node_modules/

# React production build — generated by: npm run build
# Vercel will build this automatically from your source code.
frontend/build/

# npm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE / EDITOR ---
# These are personal editor settings. Other developers have their own.
.vscode/
.idea/
*.swp
*.swo
*.swn
*~

# --- OPERATING SYSTEM ---
# macOS metadata files
.DS_Store
.AppleDouble
.LSOverride

# Windows thumbnail cache
Thumbs.db
ehthumbs.db
Desktop.ini

# --- LOGS ---
*.log
logs/

# --- MISC ---
# Coverage reports from testing tools
.coverage
htmlcov/
.pytest_cache/

# --- PRIVATE KEYS ---
*.pem
*.key
*.p12
*.pfx
INSTANCE-KEY.pem